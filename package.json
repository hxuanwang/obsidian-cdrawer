{
  "name": "obsidian-cdrawer",
  "version": "0.1.0",
  "description": "Obsidian plugin: insert and edit commutative diagrams on a fixed grid.",
  "main": "main.js",
  "type": "module",
  "scripts": {
    "dev": "node esbuild.config.mjs",
    "build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production",
    "test": "node --test --import tsx tests/*.spec.ts"
  },
  "keywords": [
    "obsidian",
    "commutative-diagram",
    "tikzcd",
    "math"
  ],
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^16.11.6",
    "builtin-modules": "^3.3.0",
    "esbuild": "0.17.3",
    "obsidian": "latest",
    "tslib": "2.4.0",
    "tsx": "^4.7.0",
    "typescript": "4.7.4"
  }
}
